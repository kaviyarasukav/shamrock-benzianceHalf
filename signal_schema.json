{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Strategy Signal",
  "description": "Standardized contract for signals generated by Quant/AI agents to be sent to the Execution Engine.",
  "type": "object",
  "properties": {
    "signal_id": {
      "type": "string",
      "description": "Unique identifier for this signal"
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds"
    },
    "strategy_id": {
      "type": "string",
      "description": "Identifier of the strategy/agent generating the signal (e.g., 'SMC_LTF_V1')"
    },
    "symbol": {
      "type": "string",
      "description": "Trading pair symbol (e.g., 'BTCUSDT')"
    },
    "action": {
      "type": "string",
      "enum": ["BUY", "SELL", "CLOSE_LONG", "CLOSE_SHORT", "HALT"],
      "description": "The intended action"
    },
    "order_type": {
      "type": "string",
      "enum": ["MARKET", "LIMIT"],
      "description": "Execution type"
    },
    "price": {
      "type": "number",
      "description": "Target price (required if order_type is LIMIT)"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Confidence score or weight of the signal (0-100)"
    },
    "metadata": {
      "type": "object",
      "description": "Additional context (e.g., timeframe, NLP sentiment score)",
      "additionalProperties": true
    }
  },
  "required": ["signal_id", "timestamp", "strategy_id", "symbol", "action", "order_type", "weight"]
}
